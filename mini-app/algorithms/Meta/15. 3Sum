class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        #step1: sort the array
        nums.sort()
        res = []

        for i in range(len(nums)):
            if nums[i] > 0: break #3sum > 0
            # 跳过重复的固定数
            if i > 0 and nums[i] == nums[i-1]: continue

            l, r = i+1, len(nums)-1
            while l < r:
                s = nums[i] + nums[l] + nums[r]
                if s < 0:
                    l += 1
                elif s > 0:
                    r -= 1
                else:
                    res.append([nums[i], nums[l], nums[r]])
                    # 跳过左指针重复元素
                    while l < r and nums[l] == nums[l+1]: l += 1 #left side remove the repeat one
                    # 跳过右指针重复元素
                    while l < r and nums[r] == nums[r-1]: r -= 1 #right side remove the repeat one
                    l += 1
                    r -= 1

        return res

