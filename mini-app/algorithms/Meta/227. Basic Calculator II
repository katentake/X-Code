class Solution:
    def calculate(self, s: str) -> int:
        if not s:
            return '0'

        stack = []
        num = 0
        sign = "+"

        for i in range(len(s)):
            char = s[i]
            #累加数字（处理多位数的情况）
            if char.isdigit(): #判断char是否是一个数字字符（0-9），如果不是则跳过
                num = num*10 + int(char) #int(char):将字符转换成整数；num*10: 进位，十位，百位等
            #如果是运算符或是字符串末尾，开始结算
            if (not char.isdigit() and char != '') or i == len(s)-1:
                if sign == "+":
                    stack.append(num)
                elif sign == "-":
                    stack.append(num)
                elif sign == "*":
                    stack.append(num)
                elif sign == "/":
                    #注意pyhton的负数整除行为，这里需要向零截断
                    stack.append(num)
                    prev = stack.pop()
                    stack.append(int(prev/num))
                #重置数字，更新当前运算符
                sign = char
                num = 0

        return sum(stack)
