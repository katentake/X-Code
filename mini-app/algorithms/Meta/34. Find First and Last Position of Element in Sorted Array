class Solution:
    def searchRange(self, nums: List[int], target: int) -> List[int]:
        """
        binary sreach
        #step1: find the left
        #step2: find the right
        #return [find_left(nums, target), find_right(nums, target)]
        """
        def find_left(nums, target):
            l, r = 0, len(nums)-1
            left_idx = -1

            while l <= r:
                mid = (l+r) // 2
                if nums[mid] == target:
                    left_idx = mid
                    r = mid +1 #找到目标后，继续向左收缩找最左侧的
                elif nums[mid] < target:
                    l =  mid+1
                else:
                    r = mid-1
            return left_idx

        def find_right(nums, target):
            l , r = 0, len(nums)-1
            right_idx = -1

            while l <= r:
                mid = (l+r)  // 2
                if nums[mid] == target:
                    right_idx = mid
                    l = mid +1 # 找到目标后，继续向右收缩找最右侧的
                elif nums[mid] < target:
                    l = mid +1
                else:
                    r = mid -1
            return right_idx

        return [find_left(nums, target), find_right(nums, target)]