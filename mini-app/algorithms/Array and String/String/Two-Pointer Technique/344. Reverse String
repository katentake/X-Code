#Method 1: slice
class Solution:
    def reverseString(self, s: List[str]) -> None:
        """
        Do not return anything, modify s in-place instead.
        """
        s[:] = s[::-1] #在原地址上，将原数组翻转并填入新内容
        return s[]


#Method 2 #D&C with two pointer
class Solution:
    def reverseString(self, s: List[str]) -> None:
        """
        Do not return anything, modify s in-place instead.
        """
        def helper(left, right):
            if left < right:
                return 

                s[left], s[right] = s[right], s[left]
                helper(left+1, right-1)

            helper(0, len(s)-1)

#Method 3: Iteration with two pointer
class Solution:
    def reverseString(self, s: List[str]) -> None:
        left, right = 0, len(s)-1

        while left < right:
            s[left], s[right] = s[right], s[left]
            left += 1
            right -= 1

        return []
