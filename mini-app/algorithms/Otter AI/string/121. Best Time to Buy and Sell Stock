class Solution:
    def maxProfit(self, prices: list[int]) -> int:
        if not prices:
            return None

        min_price = prices[0] #初始化最低价格为第一天的价格
        max_profit = 0 #初始化最大利润为0

        #如果当前价格比历史最低还低，更新最低价格
        for price in prices:
            if price < min_price:
                min_price = price
            #否则计算如果今天卖出能赚多少，并尝试更新最大利润
            elif price - min_price > max_profit:
                max_profit = price - min_price
        return max_profit

TC: O(N)
SC: O(1) 