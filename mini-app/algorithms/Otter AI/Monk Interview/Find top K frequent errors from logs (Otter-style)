# 面对海量（Massive/Huge）日志数据，面试官考察的是你对内存管理和处理效率的理解。
# 当日志文件大到无法一次性读入内存（比如 100GB 的 .log 文件）时，直接使用 logs = [...] 这种列表存储方式会导致程序崩溃（OOM - Out of Memory）。
# 以下是针对海量数据的优化方案：
# 1. 使用生成器（Generator）进行流式读取
# 不要一次性读取整个文件，而是使用 Python 的文件迭代器。它每次只读取一行到内存中，处理完后立即释放，内存占用极低且恒定。
from collections import Counter
import heapq

def get_top_k_errors_large_file(file_path, k):
    counts = Counter()
    # 增加 try-except 保护，处理编码或读取错误
    try:
    # 优化点 1: 流式读取文件，内存占用与文件大小无关
        with open(file_path, 'r', encoding='utf-8') as f:
            for line in f:
                # 优化点 2: 快速过滤，只处理 ERROR 行
                if line.startswith("ERROR "):
                    # 第二层防护：确保这行日志格式正确
                    try:
                        # 提取错误消息
                        parts = line.split(" ", 1)
                        if len(parts) >= 1:
                            msg = parts[1].strip() #剔除包括空格、制表符 \t、换行符 \n
                            counts[msg] += 1
                    except IndexError:
                        # 如果这一行格式不对（只有 ERROR 没有内容），跳过它读下一行
                        continue
    except FileNotFoundError:
        return "File not found"
    # 优化点 3: 使用 heap 取得 Top K
    # 如果错误种类也非常多，使用 counts.most_common(k) 
    # 它的内部实现是基于堆的，复杂度为 O(M log K)
    return counts.most_common(k)

