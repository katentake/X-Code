from collections import Counter

def get_top_k_errors(logs: list[str], k: int) -> list[str]:
    # 1. 过滤出以 "ERROR" 开头的日志，并提取具体的错误信息部分
    # 假设格式统一为 "ERROR message..."，我们通过 split(" ", 1) 来分割
    error_msgs = []
    for log in logs:
        if log.startswith("ERROR "): #startswith("ERROR") 表达的是：“我正在寻找错误类型的日志。”
            # split(" ", 1) 表示只分割第一个空格，取索引 1 的部分即为消息体
            parts = log.split(" ", 1)
            if len(parts) >= 1:
                error_msgs.append(parts[1])
    
    # 2. 使用 Counter 进行计数
    counts = Counter(error_msgs)
    
    # 3. 获取出现频率最高的 K 个元素
    # most_common(k) 会返回一个列表，包含前 k 个 (元素, 次数) 元组，已按次数降序排列
    top_k_pairs = counts.most_common(k)
    
    # 4. 只返回消息文本
    return [item[0] for item in top_k_pairs]

# 测试数据
logs = [
