#BFS
class Solution:
    def levelOrder(self, root: Optional[TreeNode]) -> List[List[int]]:
        if not root:
            return []
        res = []
        current_level = [root]

        while current_level:
            vals = []
            for node in current_level:
                vals.append(node.val)
            res.append(vals)

            next_level = []
            for node in current_level:
                if node.left:
                    next_level.append(node.left)
                if node.right:
                    next_level.append(node.right)
            current_level = next_level

        return res

TC: O(N)
SC: O(N)

#DFS
class Solution:
    def levelOrder(self, root: Optional[TreeNode]) -> List[List[int]]:
        res = []

        def dfs(node, level):
            if not node:
                return []
            # 如果是第一次到达这一层，先创建一个空列表
            if len(res) == level:
                res.append([])
            # 将当前节点值加入对应层的列表中
            res[level].append(node.val)
            # 递归处理左右子树，层级 +1
            dfs(node.left, level+1)
            dfs(node.right, level+1)
            
        dfs(root, 0) #表示从root根节点，0是起始层开始
        
        return res