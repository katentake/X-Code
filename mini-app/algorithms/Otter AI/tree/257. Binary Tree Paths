class Solution:
    def binaryTreePaths(self, root: Optional[TreeNode]) -> List[str]:
        if not root:
            return []

        res = []
        # 栈中元素格式为: (当前节点, 走到该节点时的路径)
        stack = [(root, str(root.val))]

        while stack:
            node, path = stack.pop() #栈里存的每一个元素都是一个元组（Tuple），格式为：(node, path)
            # 如果是叶子节点，将路径加入结果
            if not node.left and not node.right:
                res.append(path)
            # 先压入右子节点，后压入左子节点（这样弹栈时会先处理左子节点，符合常规前序遍历）
            if node.right:
                stack.append((node.right, path + "->" + str(node.right.val)))
            if node.left:
                stack.append((node.left, path + "->" + str(node.left.val)))

        return res

Method: DFS
TC: O(N)
SC: O(N)