        self.size += 1

    def deleteAtIndex(self, index: int) -> None:
        if index < 0 or index >= self.size:
            return
        # 关键：找到待删除位置的“前驱节点”
        pred = self.dummy
        for _ in range(index):
            pred = pred.next

        # 删除操作：跳过被删除节点
        pred.next = pred.next.next
        self.size -= 1
        


