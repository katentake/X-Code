import time
from collections import deque, defaultdict

class RateLimiter:
    def __init__(self, n: int):
        self.n = n  # 每秒允许的最大请求数
        self.user_requests = defaultdict(deque) # user_id -> 时间戳队列

    def is_allowed(self, user_id: str) -> bool:
        now = time.time()
        window = self.user_requests[user_id]
        
        # 1. 移除超过 1 秒之前的旧请求记录（滑动窗口移动）
        while window and now - window[0] >= 1.0:
            window.popleft()
            
        # 2. 判断当前窗口内的请求数是否达到上限 N
        if len(window) < self.n:
            # 3. 记录当前请求的时间戳
            window.append(now)
            return True
            
        return False

# --- 使用示例 ---
limiter = RateLimiter(n=3)  # 每秒允许 3 个请求
user = "user_123"

for i in range(5):
    allowed = limiter.is_allowed(user)
    print(f"请求 {i+1}: {'通过' if allowed else '被限流'}")
    time.sleep(0.2) # 模拟请求间隔

