import time
import threading

class RateLimiter:
    def __init__(self, capacity, fill_rate):
        """
        :param capacity:
        :param fill_rate:
        """
        self.capacity = float(capacity) # capacity: 桶的最大容量，决定了允许的最大突发请求量
        self._tokens = float(capacity) # _tokens: 当前桶里的令牌数，初始化为满桶
        self.fill_rate = float(fill_rate) # fill_rate: 令牌填充速率（例如每秒生成多少个令牌
        self.last_time = time.time() # last_time: 记录上一次补充令牌的时间点
        self.lock = threading.Lock() # lock: 创建一个线程锁，确保在多线程环境下对令牌计数的操作是安全的

    def allow_request(self, tokens=1):
        with self.lock: # 使用 with 语句自动获取和释放锁，防止并发竞争导致计数错误
            now = time.time() # 计算从上次请求到现在经过了多久，并据此计算应补充的令牌数
            delta = (now - self.last_time) * (self.fill_rate) # delta = 时间差 * 填充速率

            # 更新当前令牌桶里的数量，但不能超过桶的最大容量 capacity
            self._tokens = min(self.capacity, self._tokens + delta)
            # 更新“上次时间”为当前时间
            self.last_time = now

            # 判断桶里的令牌是否足够支付本次请求需要的 tokens（默认 1 个）
            if self._tokens >= tokens:
                # 如果足够，扣除对应数量的令牌
                self._tokens -= tokens
                # 返回 True，代表允许本次请求通过
                return True
            # 令牌不足，返回 False，代表触发限流，拒绝请求
            return False

#sample
limiter = RateLimiter(capacity=5, fill_rate=1)

for i in range(8):
    if limiter.allow_request():
        print(f"request {i}: pass")
    else:
        print(f"request {i}: limit")
    time.sleep(0.5)


