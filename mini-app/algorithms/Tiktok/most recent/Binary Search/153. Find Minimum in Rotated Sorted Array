#Method: Binary Search

class Solution:
    def search(self, nums: List[int]) -> int:
        left, right = 0, len(nums)-1

        while left < right:
            mid = (left + right) // 2
            if nums[mid] > nums[right]:  # 说明最小值一定在 mid 右侧，且 mid 绝不可能是最小值
                left = mid +1
            else:
                # 说明 mid 可能是最小值，或者最小值在 mid 左侧
                # 因为 mid 自己有可能是答案，所以绝对不能写成 mid - 1
                right = mid

        return nums[left]

TC: O(log n)
SC: O(1)