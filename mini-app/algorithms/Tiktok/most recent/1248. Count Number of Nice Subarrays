class Solution:
    def numberOfSubarrays(self, nums: List[int], k: int) -> int:
        # count[v] 表示前缀和为 v 的出现次数
        count = {0:1}
        curr_sum = 0
        res = 0

        for num in nums:
            # 奇数贡献 1，偶数贡献 0
            curr_sum += num&1
            if curr_sum - k in count:
                res += count[curr_sum - k]  #如果 cur_sum - k 在哈希表中存在，说明前面有 count[cur_sum - k] 个位置
            #把当前最新的前缀和 cur_sum 记录到哈希表中
            count[curr_sum] = count.get(curr_sum, 0) + 1

        return res

TC: O(N)
SC: O(N)
