#解法 1：记忆化搜索 (DFS + Memoization)

class Solution:
    def longestIncreasingPath(self, matrix: list[list[int]]) -> int:
        if not matrix or not matrix[0]:
            return 0

        m, n = len(matrix), len(matrix[0])
        # memo[r][c] 表示从 (r, c) 出发的最长递增路径长度
        memo = [[0]*n for _ in range(m)]

        def dfs(r, c):
            # 如果已经计算过，直接返回缓存结果
            if memo[r][c] != 0:
                return memo[r][c]

            max_len = 1 # 初始长度为自身

            directions = [(0, -1), (-1, 0), (0, 1), (1, 0)]
            for dr, dc in directions:
                nr, nc = r+dr, c+dc
                # 检查边界，并确保下一步的数值严格大于当前数值
                if 0 <= nr < m and 0 <= nc < n and matrix[nr][nc] > matrix[r][c]:
                    max_len = max(max_len, 1+dfs(nr, nc))

            memo[r][c] = max_len
            return max_len

        # 遍历矩阵中的每一个点作为起点，求全局最大值
        retrun max(dfs(r, c) for r in range(m) for c in range(n))

TC: O(M*N)
SC: O(M*N)