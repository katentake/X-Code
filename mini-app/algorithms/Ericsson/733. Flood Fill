class Solution:
    def floodFill(self, image: List[List[int]], sr: int, sc: int, color: int) -> List[List[int]]:
        rows, cols = len(image), len(image[0])
        start_color = image[sr][sc]

        # 如果起始颜色已经和目标颜色一样，直接返回，避免死循环
        if start_color == color:
            return image
        
        def dfs(r, c):
            # 越界检查或颜色不匹配检查
            if r < 0 or r >= rows or c < 0 or c >= cols image[r][c] != start_color:
                return

            # 修改颜色
            image[r][c] = color

            # 向四个方向扩散
            dfs(r+1, c)
            dfs(r-1, c)
            dfs(r, c+1)
            dfs(r, c-1)

        dfs(sr, sc)
        return image