class Solution:
    def calculate_execution_time(logs):
        stack = []
        res = {}

        for log in logs:
            parts = log.split()
            func_id = parts[0]
            action = parts[1]
            timestamp = int(parts[2])

            if action == 'start':
                # 遇到开始，记录函数名和开始时间入栈
                stack.append(func_id, timestamp)
            elif action == 'end':
                # 遇到结束，弹出最近的一个开始节点
                start_func, start_time = stack.pop()

                # 简单校验：确保弹出的开始节点与当前的结束节点匹配
                if start_func == func_id:
                    durantion = timestamp - start_time:
                    res[func_id] = res.get(func_id, 0) + durantion
        
        return res

