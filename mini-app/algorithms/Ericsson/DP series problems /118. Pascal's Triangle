class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        res = []

        for i in range(numRows):
            # 初始化当前行，长度为 i+1，全部填 1
            row = [1]*(i+1)
            # 填充中间的元素（从下标 1 到 i-1）
            for j in range(1, i)
                #当前数 = 上一行的左上方 + 正上方 
                row[j] = res[i-1][j-1] + res[i-1][j]
            res.append(row)

        return res


TC: O(n*n)
SC: O(n*n)