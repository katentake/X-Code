class Solution:
    def getRow(self, rowIndex: int) -> List[int]:
        # 初始化: 构建第一行(row) 因为从领开始的(rowIndex = 0)
        res = [1]*(rowIndex + 1)

        # 外层循环：从第 1 行处理到第 rowIndex 行
        for i in range(1, rowIndex):
            # 内层循环：从 i 位置倒序更新到 1 位置
            for j in range(i, 0, -1): #倒序
                # 当前值 = 上一行的当前位置 + 上一行的前一个位置
                res[j] += res[j-1]

        return res

#TC: O(n*n)
#SC: O(N)