class Solution:
    def isSubsequence(self, s: str, t: str) -> bool:
        i, j = 0, 0

        while i < len(s) and j < len(t):
            # 如果字符匹配，s 的指针向后移动
            if s[i] == t[j]:
                i += 1
            # 无论是否匹配，t 的指针都要后移
            j += 1
        # 如果 i 能够走到 s 的末尾，说明 s 是 t 的子序列
        return i == len(s)

TC: O(T)
SC: O(1)