class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        if not prices:
            return None

        #1 初始化最低价格为第一天的价格
        min_price = prices[0]
        #2 初始化最大利润为 0
        max_profit = 0
        
        #3 如果当前价格比历史最低还低，更新最低价格
        for price in prices:
            if price < min_price:
                min_price = price
            #4 否则，计算如果今天卖出能赚多少，并尝试更新最大利润
            elif price - min_price > max_profit
            max_profit = price - min_price

        return max_profit