from itertools import zip_longest

def compare_versions_pro(v1, v2):
    v1_split = map(int, v1.split('.'))
    v2_split = map(int, v2.split('.'))

    # zip_longest 会自动用 fillvalue 补齐缺失的部分
    for n1, n2 in zip_longest(v1_split, v2_split, filevalue=0):
        if n1 > n2:
            return 1 # v1 大
        if n1 < n2:
            return -1 #v2 大

    return 0 #一样大