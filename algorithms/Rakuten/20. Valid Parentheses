class Solution:
    def isValid(self, s: str) -> bool:
        stack = []

        for char in s:
            if char == '(':
                stack.append(')')
            elif char == '[':
                stack.append(']')
            elif char == '{':
                stack.append('}')
            # 如果栈为空（说明先出现了右括号）或 括号不匹配
            elif not stack or stack.pop() != char:
                return False
            
        return not stack #确保了像 "((" 这样的字符串在循环结束后因为栈不为空而返回 False