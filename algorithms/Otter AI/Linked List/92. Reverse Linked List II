class Solution:
    def reverseBetween(self, head: Optional[ListNode], left: int, right: int) -> Optional[ListNode]:
        # 设置 dummy 节点处理 left=1 的情况
        dummy = ListNode(0)
        dummy.next = head
        prev = dummy

        # 1. 移动 pre 到待反转区间的前一个节点
        for _ in range(left - 1):
            prev = prev.next

        # 2. 开始反转：curr 是反转区间的第一个节点
        curr = prev.next
        for _ in range(right - left):
            # 暂存待移动的节点
            nxt = curr.next
            curr.next = nxt.next # 斩断curr与nxt的联系，接上更后面的节点
            nxt.next = prev.next # 将nxt插到pre后面
            prev.next = nxt

        return dummy.next