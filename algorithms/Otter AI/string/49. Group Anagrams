class Solution:
    def groupAnagrams(self, strs: List[List[str]]) -> List[List[str]]:
        res = defaultdict(list)

        for s in strs:
            # 将字符串排序并作为 key (必须转回 tuple 或 string，因为 list 不可哈希)
            key = "".join(sorted(s))
            res[key].append(s)
        return list(res.values())

TC: O(N.KlogK)
SC: O(N.K)
