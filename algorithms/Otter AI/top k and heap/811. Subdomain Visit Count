class Solution:
    def subdomainVisits(self, cpdomains: List[str]) -> List[str]:
        res = Counter()

        for cp in cpdomains:
            count, domain = cp.split() #第一个元素赋值给变量 count，第二个元素赋值给 domain
            count = int(count) #转换成int利于之后的数字统计
            frags = domain.split('.')

            # 另一种提取子域名的方法：通过 '.' 的位置查找
            for i in range(len(frags)):
                res[".".join(frags[i:])] += count

        return ["{} {}".format(v, k) for k, v in res.items()]

TC: O(L)
SC: O(L)

#res 是一个 Counter（或字典），里面存储的数据结构类似于：{"com": 951, "leetcode.com": 9001}。
#.items() 会将字典转换成一个可遍历的列表，每个元素是一个元组：[("com", 951), ("leetcode.com", 9001)]。

#在 for k, v in res.items() 中：
#k (key) 代表域名，如 "com"。
#v (value) 代表访问次数，如 951。
#"{} {}".format(v, k)这是字符串格式化操作，用来构造题目要求的 "次数 域名" 格式。
#第一个 {} 会被变量 v（次数）替换。
#第二个 {} 会被变量 k（域名）替换。
#示例：如果 v=951, k="com"，执行结果就是字符串 "951 com"。
