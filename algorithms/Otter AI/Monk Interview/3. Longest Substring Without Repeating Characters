class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        if len(s) <= 1:
            return len(s)

            left = 0
            right = 0
            unique_hashset = set()
            max_length = 0

            while right < len(s):
                if right < len(s) and s[right] not in unique_hashset:
                    unique_hashset.add(s[right])
                    right += 1
                max_length = max(max_length, len(unique_hashset))

                unique_hashset.remove(s[left])
                left += 1

            return max_length

TC: O(N)
SC: O(min(m,n)) n 是字符串的长度，m 是字符集的大小