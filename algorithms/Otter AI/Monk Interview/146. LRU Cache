from collections import OrderedDict

class LRUCache:
    def __init__(self, capacity: int):
        self.cache = OrderedDict()
        self.capacity = capacity

    def get(self, key: int) -> int:
        if key not in self.cache:
            return -1
        self.cache.move_to_end(key)
        return self.cache[key]

    def put(self, key: int, value: int) -> None:
        if key in self.cache:
            self.cache.move_to_end(key)
        self.cache[key] = value
        if len(self.cache) > self.capacity:
            self.cache.popitem(last=False)

TC: O(1)
SC: O(capacity)

class ListNode:
    """双向链表节点定义"""
    def __init__(self, key=0, value=0):
        self.key = key
        self.value = value
        self.prev = None
        self.next = None

class LRUCache:

    def __init__(self, capacity: int):
        self.capacity = capacity
        self.hash_map = {}  # key -> ListNode
        
        # 初始化虚拟头、尾节点
        self.head = ListNode()
        self.tail = ListNode()
        self.head.next = self.tail
        self.tail.prev = self.head

    def get(self, key: int) -> int:
        if key not in self.hash_map:
            return -1
        node = self.hash_map[key]
        # 只要被访问了，就移动到链表尾部（表示最近使用）
        self._move_to_tail(node)
        return node.value

    def put(self, key: int, value: int) -> None:
        if key in self.hash_map:
            node = self.hash_map[key]
            node.value = value
            self._move_to_tail(node)
        else:
            if len(self.hash_map) >= self.capacity:
                # 容积满了，驱逐最久未使用的节点（即靠近 head 的第一个真实节点）
                removed = self._pop_head()
                del self.hash_map[removed.key]
                
            new_node = ListNode(key, value)
            self.hash_map[key] = new_node
            self._add_to_tail(new_node)

    # --- 以下为维护双向链表的内部辅助函数 ---
    
    def _remove_node(self, node):
        """将某个节点从链表中断开连接"""
        node.prev.next = node.next
        node.next.prev = node.prev

    def _add_to_tail(self, node):
        """将节点插入到链表尾部（临近 tail 哨兵）"""
        node.prev = self.tail.prev
        node.next = self.tail
        self.tail.prev.next = node
        self.tail.prev = node

    def _move_to_tail(self, node):
        """将现有节点提升至最新的位置"""
        self._remove_node(node)
        self._add_to_tail(node)

    def _pop_head(self) -> ListNode:
        """删除最久未使用的节点并返回它"""
        first_real_node = self.head.next
        self._remove_node(first_real_node)
        return first_real_node