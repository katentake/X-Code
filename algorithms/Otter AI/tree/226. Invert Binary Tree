class Solution:
    def invertTree(self, root: Optional[TreeNode]) -> Optional[TreeNode]:
        # 基准条件：如果节点为空，直接返回
        if not root:
            return None

        # 递归翻转左右子树
        left = self.invertTree(root.left)
        right = self.invertTree(root.right)

        # 交换当前节点的左右子节点
        root.left = right
        root.right = left

        return root

#Method: DFS
TC: O(N)
SC: O(N)