#实现 tail -f app.log

import time

with open(PATH, 'r') as file:
    #seek(offset, whence) 是用來移動檔案讀取指標（游標）的位置
    #第一個參數 0 代表移動的距離（位移量）
    #第二個參數 2 代表檔案的末尾（EOF, End of File）
    file.seek(0, 2)

    while True: #建立一個永遠不會停止的 while 迴圈
        line = file.readline() #嘗試讀取新的一行

        if not line: #檢查變數 line 是否為空
            time.sleep(1)
            continue

        print(line.strip()) #拔掉日誌結尾的換行符號 \n