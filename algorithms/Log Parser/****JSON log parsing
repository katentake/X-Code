#如何避免程序 crash？
import json

PATH = "app.log"

with open(PATH, 'r') as file:
    for line in file:
        try:
            data = json.loads(line)
            # 使用 .get() 即使没有 "level" 也会返回 None，而不会抛出 KeyError
            if data.get("level") == "ERROR":
                print(data)
        except json.JSONDecodeError:
            # 明确只捕获 JSON 解析失败的异常，日志脏了直接跳过
            continue
        except Exception as e:
            # 可选：捕获其他未知异常（如打印或记录），防止程序中断
            print(f"Unexpected error: {e}")
            continue