class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        # 将数组转换为集合，实现 O(1) 查询并去重
        hash_set = set(nums)
        res = 0

        for num in nums:
            if (num-1) not in nums: # 如果 num - 1 不在集合中，说明 num是起点，跳过
                curr = num
                curr_len = 1
                while curr+1 in hash_set: # 持续查找下一个连续的数字
                    curr_len += 1
                    curr += 1
                return max(res, curr_len) # 更新全局最长长度
        return res