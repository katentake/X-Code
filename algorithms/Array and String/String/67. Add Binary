class Solution:
    def addBinary(self, a: str, b: str) -> str:
        res = []
        carry = 0
        i, j = len(a)-1, len(b)-1

        while i >= 0 or j >= 0 or carry:
            #取出当前位置的值，如果指针越界则补0
            val_a = int(a[i]) if i >= 0 else 0:
            val_b = int(b[j]) if j >= 0 else 0:

            #计算当前位的总和与进位
            total = val_a + val_b + carry
            res.append(str(total % 2))
            carry = total // 2

            #指针左移
            i -= 1
            j -= 1

        return "".join(res[::-1]) ##因为是从低位开始存的，最后需要翻转