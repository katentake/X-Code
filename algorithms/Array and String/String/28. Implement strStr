class Solution:
    def strStr(self, haystack: str, needle: str) -> int:
        #关键点：为什么范围是 len(haystack) - len(needle) + 1？
        #假设 haystack 长度为 10，needle 长度为 3。如果你从索引 8 开始往后数，后面只剩 2 个字符了，不可能匹配上长度为 3 的 needle。因此，循环只需要进行到剩余字符长度刚好等于 needle 长度的地方即可
        for i in range(len(haystack) - len(needle) + 1):
            #细节：haystack[i : i + len(needle)] 会从当前的索引 i 开始，向后截取一个与 needle 长度完全相同的子串
            #逻辑：如果截取出来的这段字符正好等于 needle，说明我们找到了匹配项。
            if  haystack[i:i + len(needle)] == needle:
                return i

        return -1


