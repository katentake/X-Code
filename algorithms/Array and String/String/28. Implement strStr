class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        if not strs: 
            return ""

        strs.sort() #核心逻辑：将字符串数组按字典序（Alphabetical order）进行升序排序
        #排序后，数组中的第一个字符串 strs[0] 与最后一个字符串 strs[-1] 之间的差异是最大的。如果这两个字符串有共同的字母，那么中间所有的字符串在对应位置也一定有相同的字母

        first, last = strs[0], strs[-1]
        while i < len(first) and i < len(last) and first[i] == last[i]:
            i += 1

        return first[:i] #利用切片操作，返回从开头到索引 i（不含 i）的子串。这就是找到的最长公共前缀