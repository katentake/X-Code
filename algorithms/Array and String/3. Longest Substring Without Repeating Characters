#Method1 ##Sliding Window

class Solution:
    def lengthofLongestSubstring(s: str):
        seen = {} # 记录字符最后出现的位置
        left = 0  # 窗口左边界
        max_len = 0 # 最大长度

        for i in range(len(s)): # 如果字符已存在于 map 中，且在当前窗口内
            if s[i] in seen:
                left = max(left, seen[s[i]] + 1) # 调整左边界到重复字符下一位，但不能向左回跳

            seen[s[i]] = i #更新/放入当前字符的位置
            max_len = max(max_len, i- left+1)

        return max_len

#Mathod2: hashSet ans double pointer

class Solution():
    def lengthofLongestSubstring(s: str):
        if len(s) <= 1: return len(s) #base case
        left = 0
        right = 0

        unique_hashset = set() #哈希集合，用于存储当前窗口内的所有字符，方便以 O(1) 的时间复杂度判断某个字符是否重复
        max_length = 0 #记录遍历过程中出现过的最大窗口长度

        while right < len(s): #只要右指针还没走完整个字符串，就继续尝试寻找更长的子串
            while right < len(s) and s[right] not in unique_hashset: 只要当前 right 指向的字符不在集合中，说明没有重复。
                unique_hashset.add(s[right]) #将该字符加入集合，并将 right 向右移动一位
                right += 1
            max_length = max(max_length, len(unique_hashset)) #更新最大长度

            unique_hashset.remove(s[left]) #收缩窗口：移除左侧字符
            left += 1
        return max_length



        