class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int
        """
        nums = 1,2,3,2,1
        cusum= 1,3,6,8,9
        for any i=1, j=3
        """
        count = 0
        for i in range(nums):
            cusum_ij = 0
            for j in range(i, len(nums)):
                cusum_ij += nums[j] #向右移动
                if cusum_ij == k:
                count += 1

        return count