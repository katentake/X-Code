class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int
        """
        nums = 1,2,3,2,1
        cusum= 1,3,6,8,9
        for any i=1, j=3
        """
        count = 0 # 初始化计数器，用于记录和为 k 的子数组个数
        for i in range(nums):
            cusum_ij = 0 # 初始化当前子数组的和。每当起始点 i 移动，重新从 0 开始累加
            for j in range(i, len(nums)): # 内层循环：从起始位置 i 开始，向右探索所有的“结束位置” j
                # 将当前元素 nums[j] 累加到 cusum_ij 中
                # 这样可以得到从下标 i 到 j 的子数组之和
                cusum_ij += nums[j] #向右移动
                if cusum_ij == k:
                count += 1

        return count