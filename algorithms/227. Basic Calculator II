class Solution:
    def calculate(self, s:str) -> int:
        if not s: return '0'

        stack, num, sign = [], 0, "+"

        for i in range(len(s)):
            char = s[i]
            if char.isdigit():
                num = num*10+int(char)

            if (not char.isdigit() and char != ' ') or i == len(s)-1:
                if sign == "+":
                    stack.append(num)
                elif sign == "-":
                    stack.append(-num)
                elif sign == "*":
                    stack.append(stack.pop()*num)
                elif sign == "/":
                    prev = stack.pop()
                    stack.append(int(prev/num))
                
                sign = char
                num = 0

        return sum(stack)
