class Solution:
    def rightSideView(self, root: Optional[TreeNode]) -> List[int]:
        res = []

        def dfs(node, depth):
            if not node:
                return

            # 如果当前深度等于结果集的长度，说明这是我们第一次来到这一层
            # 配合“先右后左”的递归顺序，这个节点必然是该层最右侧的
            if depth == len(res):
                res.append(node.val)

            # 核心：先递归右子树，再递归左子树
            dfs(node.right, depth+1)
            dfs(node.left, depth+1)

        dfs(root, 0)

        return res