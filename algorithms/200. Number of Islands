#Methond dfs

class Solution(object):
    def numIslands(self, grid: List[List[str]]) -> int:
        if not grid: #边界处理：如果网格为空，直接返回 0
            return 0


        rows, cols = len(grid), len(grid[0])
        islands = 0


        def dfs(r, c):
            # 1. 边界检查：是否越界
            # 2. 内容检查：是否为水 '0'
            if r < 0 or r >= rows or c < 0 or c >= cols:
                return
            if grid[r][c] != '1':
                return

            grid[r][c] = '0' # 将当前陆地标记为 '0'，表示已访问（淹没岛屿）
            # 递归探索上下左右
            dfs(r + 1, c)
            dfs(r - 1, c)
            dfs(r, c + 1)
            dfs(r, c - 1)

        for r in range(rows):
            for c in range(cols):
                if grid[r][c] == '1':
                    # 每发现一个 '1'，就是一个新岛屿的开始
                    islands += 1
                    dfs(r, c)

        return islands