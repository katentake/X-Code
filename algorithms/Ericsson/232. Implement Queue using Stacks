class MyQueue:
    #初始化
    def __init__(self):
        self.s1 = [] ## 输入栈：所有 push 操作的新元素都先存在这里
        self.s2 = [] ## 输出栈：用于 pop 和 peek，里面的元素顺序是队列顺序

    #入队操作
    def push(self, x: int) -> None:
        stack.s1.append(x) # 直接压入 s1，时间复杂度 O(1)

    #出对操作
    def pop(self) -> int:
        # 1. 检查输出栈 s2 是否为空
        if not self.s2: 
            # 2. 如果 s2 为空，就把 s1 里的元素全部“倒”进 s2
            # 这样 s1 底部（最早进入的）就变成了 s2 的顶部
            while self.s1:
                self.s2.append(self.s1.pop())
        # 3. 从 s2 弹出顶部元素，这正是队列中最早进入的元素
        return self.s2.pop()

    #查看队首元素
    def peek(self) -> int:
        # 1. 逻辑与 pop 类似，确保 s2 中有当前队列最前面的元素
        if not self.s2:
            while self.s1:
                self.s2.append(self.s1.pop())
        # 2. 返回 s2 的栈顶元素（即索引为 -1 的位置），但不弹出
        return self.s2[-1]

    #判断是不是空
    def empty(self) -> bool:
        # 只有当两个栈都为空时，说明队列里没有任何元素
        return max(len(self.s1), len(self.s2)) == 0