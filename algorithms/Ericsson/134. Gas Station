class Solution:
    def canCompleteCircuit(self, gas: List[int], cost: List[int]) -> int:
        #如果总油量小于总消耗，一定无法跑完一圈
        if  sum(gas) < sum(cost):
            return -1

        total = 0 # 当前油箱的油量
        res = 0 # 记录潜在的起点索引
        for i in range(len(gas)):
            #计算到达第 i 站并尝试前往下一站后的净剩余油量。(gas[i] - cost[i]) 是这一站对油箱的“贡献度”（可能是正数也可能是负数）
            total += (gas[i] - cost[i]) 

            if total < 0: #说明从当前的 res 出发，根本无法到达第 i+1 站
                #我们将起点 res 暂时重置为下一站 i + 1，并将当前油箱 total 清零重新开始统计。
                total = 0
                res = i+1

        return res