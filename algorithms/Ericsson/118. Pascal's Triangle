class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        res = []

        for i in range(numRows):
            # 每一行的长度等于 行号 + 1，首尾初始化为 1
            row = [1] * (i+1)
            
            # 计算中间的元素
            for j in range(1, i):
                row[j] = res[i-1][j-1] + res[i-1][j]

            res.append(row)

        return res