class Solution:
    def uniquePathsWithObstacles(self, grid: List[List[int]]) -> int:
        #m 是row, n是col
        m, n = len(grid), len(grid[0]) 
        dp = [0]*n 

        # 起点初始化
        if grid[0][0] == 0:
            dp[0] = 1 #代表到达起点游戏开始
        else:         # grid[0][0] == 1
            dp[0] = 0 #起点就是障碍物（值为 1）

        for i in range(m):
            for j in range(n):
                if grid[i][j] == 1:
                    dp[j] = 0 # 遇到障碍，路径断了
                elif j > 0:
                    dp[j] += dp[j-1] # 当前格路径 = 上方(旧dp[j]) + 左侧(新dp[j-1])

        return dp[-1]

#TC: O(m*n)
#SC: O(n)