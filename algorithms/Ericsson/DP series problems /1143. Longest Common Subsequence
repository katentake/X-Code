from functools import lru_cache

class Solution:
    def longestCommonSubsequence(self, text1: str, text2: str) -> int:
        @lru_cache(None)
        def dp(i, j):
            # 基准情况：任一字符串处理完毕
            if i == -1 or j == -1:
                return 0
            # 字符匹配
            if text1[i] == text2[j]:
                return dp(i-1, j-1) +1
            # 字符不匹配，取两种跳过方案的最大值
            return max(dp(i-1, j), dp(i, j-1))

        return dp(len(text1)-1, len(text2)-1) #从两个字符串的最后一位索引（长度减一）开始往前搜索，最终返回的值就是我们要的答案

TC: O(m*n)
SC: O(m*n)