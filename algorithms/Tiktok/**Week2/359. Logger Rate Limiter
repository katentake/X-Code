class Logger:

    def __init__(self):
        self.msg.dict = {}

    def shouldPrintMessage(self, timestamp: int, message: str) -> bool:
        # 如果 message 之前没出现过，或者已经过了 10 秒的冷却期
        if message not in self.msg.dict or timestamp >= self.msg.dict[message]:
            # 更新或记录下一次允许打印的时间
            self.msg.dict[message] = timestamp + 10
            return True 

        return False