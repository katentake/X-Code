Method: 块编码 / 长度前缀法
class Codec:
    def encode(self, strs: list[str]) -> str:
        """
        Encodes a list of strings to a single string.
        """
        for s in strs:
            # 格式： 长度 + # + 字符串本身
            res.append(f"{len(s)#{s}}")
        return "".join(res)

    def decode(self, s: str) -> list[str]:
        """
        Decodes a single string to a list of strings.
        """
        res = []
        i = 0

        while i < len(s):
            # 找到当前分块长度结束的那个 '#'
            j = i
            while s[j] != '#':
                j += 1

            # 提取出长度
            length = int(s[i:j])

            # 根据长度精确截取字符串本身
            start = j + 1
            end = start + length
            res.append(s[start:end])

            # 指针移动到下一个分块的起点
            i = end

        return res

TC: O(N)
SC: O(1)
