Method: 哈希表 + 最小堆
import time
import heapq

class TTLCacheWithHeap:
    def __init__(self, ttl: int):
        self.ttl = ttl
        self.cache = {}  # {key: (value, expire_time)}
        self.heap = []  # 最小堆，存放 (expire_time, key)

    
    def _clean_expired(self, current_time: float) -> None:
        # 循环检查堆顶，只要过期了就弹出来清除
        while self.heap and self.heap[0][0] <= current_time:
            expire_time, key = heapq.heappop(self.heap)
            # 注意：同一个 key 可能被多次 put，所以要确认哈希表里的过期时间是否和堆里的一致
            if key in self.cache and self.cache[key][1] == expire_time:
                del self.cache[key]


    def put(self, key: int, value: int) -> None:
        now = time.time()
        self._clean_expired(now)  # 先扫除垃圾

        expire_time = now + self.ttl
        self.cache[key] = (value, expire_time)
        heapq.heappush(self.heap, (expire_time, key))


    def get(self, key: int) -> int:
        now = time.time()
        self._clean_expired(now)  # 先扫除垃圾

        if key not in self.cache:
            return -1

        return self.cache[key][0]

TC: O(log n)
SC: O(n)
