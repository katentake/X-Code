class Solution:
    def searchRange(self, nums: list[int], target: int) -> list[int]:
        def findLeft(nums, target):
            l, r = 0, len(nums) - 1
            left_idx = -1
            while l <= r:
                mid = (l + r) // 2
                if nums[mid] == target:
                    left_idx = mid
                    r = mid - 1  # 锁定目标后，继续向左收缩找最左侧的
                elif nums[mid] < target:
                    l = mid + 1
                else:
                    r = mid - 1
            return left_idx

        def findRight(nums, target):
            l, r = 0, len(nums) - 1
            right_idx = -1
            while l <= r:
                mid = (l + r) // 2
                if nums[mid] == target:
                    right_idx = mid
                    l = mid + 1  # 锁定目标后，继续向右收缩找最右侧的
                elif nums[mid] < target:
                    l = mid + 1
                else:
                    r = mid - 1
            return right_idx

        return [findLeft(nums, target), findRight(nums, target)]

TC: O(log n)
SC: O(1)