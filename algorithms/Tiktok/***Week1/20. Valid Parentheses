class Solution:
    def isValid(self, s: str) -> bool:
        stack = []

        for char in s:
            if char == '(':
                stack.append(')')
            elif char == '[':
                stack.append(']')
            elif char == '{':
                stack.append('}')
            elif not stack or stack.pop() != char: #如果栈为空 or 括号不匹配
                return False

        return not stack #确保 “（（”这样的字符串在循环结束后因为栈不为空而返回false

TC: O(N)
SC: O(N)