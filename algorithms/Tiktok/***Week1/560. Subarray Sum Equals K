class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        count = 0
        curr_sum = 0

        # 哈希表：key 为前缀和，value 为该前缀和出现的次数
        # 初始化 {0: 1} 是为了处理从数组开头到当前位置的子数组和正好等于 k 的情况
        prefix_sum = {0: 1}

        for num in nums:
            curr_sum += num # 计算当前的前缀和

            # 如果 current_sum - k 已经在哈希表中，说明找到了符合条件的子数组
            if curr_sum - k in prefix_sum:
                count += prefix_sum[curr_sum - k]
            
            # 将当前前缀和存入哈希表
            prefix_sum[curr_sum] = prefix_sum.get(curr_sum, 0) + 1

        return count

TC: O(n)
SC: O(n)