class Solution:
    def pathSum(self, root: Optional[TreeNode], targetSum: int) -> int:
        # 哈希表记录路径前缀和出现的次数
        # 初始化：前缀和为 0 出现过 1 次（代表从根节点开始就直接满足 targetSum 的情况）
        prefix_sums = defaultdict(int)
        prefix_sums[0] = 1

        def dfs(node, curr_sum):
            if not node:
                return 0

            # 更新当前从根节点到该节点的累加和
            curr_sum += node.val

            # 看看需要的前缀和（curr_sum - targetSum）在之前出现过多少次
            count = prefix_sums[curr_sum - targetSum]

            # 将当前前缀和加入哈希表，供子树使用
            prefix_sums[curr_sum] += 1

            # 递归遍历左右子树，并累加满足条件的路径数
            count += dfs(node.left, curr_sum)
            count += dfs(node.right, curr_sum)

            # 【状态恢复/回溯】离开当前节点时，将其从当前路径的前缀和中移除
            prefix_sums[curr_sum] -= 1

            return count
        
        return dfs(root, 0)


TC: O(N)
SC: O(1)