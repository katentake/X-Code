from collections import Counter

class Solution:
    def removeDuplicateLetters(self, s: str) -> str:
        # 统计每个字符的总出现次数
        count = Counter(s)

        stack = []
        visited = set()

        for char in s:
            # 每遍历一个字符，它在后续字符串中的剩余次数就少一次
            count[char] -= 1

            if char in visited:
                continue

            # 如果当前字符比栈顶小，且栈顶字符在后面还有剩余，则弹出栈顶
            while stack and char < stack[-1] and count[stack[-1]] > 0:
                removed_char = stack.pop()
                visited.remove(removed_char)

            stack.append(char)
            visited.add(char)

        return "".join(stack)

TC: O(N)
SC: O(1)
