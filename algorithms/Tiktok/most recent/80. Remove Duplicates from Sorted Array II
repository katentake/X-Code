class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        if len(nums) <= 2:
            return len(nums)

        slow = 2 # 前两个元素一定可以保留
        for fast in range(2, len(nums)):
            # 检查当前快指针的值是否与慢指针倒数第二个写入的值相同
            if nums[fast] != nums[slow -2]:
                nums[slow] = nums[fast]
                slow += 1

        return slow

TC: O(log n)
SC: O(1)