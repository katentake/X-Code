#Method: dp 

class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        row = [1] * n 

        for i in range(1, m):
            for j in range(1, n):
                #row[j]此时还是上一行的旧值， row[j-1]是当前刚更新的左侧值
                row[j] += row[j-1]

        return row[-1]


TC: O(m*n)
SC: O(n)

