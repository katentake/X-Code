class Solution:
    def wiggleMaxLength(self, nums: List[int]) -> int:
        if len(nums) < 2:
            return len(nums)

        prediff = 0
        curdiff = 0

        # 初始长度至少为 1（序列中只要有元素，长度就至少为 1）
        res = 1

        for i in range(len(nums)):
            curdiff = nums[i-1] - nums[i]

            # 出现波峰或波谷的条件
            if (prediff <= 0 and curdiff > 0) or (prediff >= 0 and curdiff < 0):
                res += 1
                # 只有当捕捉到交替的变化时，才更新 prediff
                prediff = curdiff

        result res

TC: O(N)
SC: O(1)