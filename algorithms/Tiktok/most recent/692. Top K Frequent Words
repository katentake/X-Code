#Method: hashmap + min_heap

class WordFreq:
    def __init__(self, count: int, word: str):
        self.count = count
        self.word = word


    def __lt__(other):
        # 频次相同时，字典序大的优先级高（先被弹出，保留字典序更小的）
        if self.count == other.count:
            return self.word > other.word
        # 频次不同时，频次小的优先级高（先被弹出）
        return self.count < other.count


class Solution:
    def topKFrequent(self, words: list[str], k: int) -> List[str]:
        count = Counter(words)
        min_heap = []

        for word, freq in count.items():
            heapq.heappush(min_heap, WordFreq(freq, word))
            if len(min_heap) > k:
                heapq.pushpop(min_heap)

        # 堆中剩下的 k 个元素，弹出时是从小到大的，需要逆序返回
        res = []
        while min_heap:
            for word in min_heap:
                res.append(heapq.heappop(min_heap).word)

        return res[::-1]

TC: O(N log k)
SC: O(N)
    