class Solution:
    minimumJumps(self, forbidden: list[int], a: int, b: int, x: int) -> int:
        forbidden_set = set(forbidden)
        max_bound = max(x, max(forbidden) if forbidden else 0) + a + b
        max_bound = max(max_bound, 6000)

        # 队列只存储 (pos, direction)
        queue = deque([(0, 1)])
        visited = {(0, 1)}
        steps = 0

        while queue:
            # 每次一口气处理完当前层的所有状态
            for _ in range(len(queue)):
                pos, direction = queue.popleft()

                if pos == x:
                    return steps

                # 向前跳
                f_pos = pos + a 
                if f_pos <= max_bound and f_pos not in forbidden_set and (f_pos, 1) not in visited:
                    visited.add((f_pos, 1))
                    queue.append((f_pos, 1))

                # 向后跳
                b_pos = pos - b
                if directions == 1 and b_pos >= 0 and b_pos not in forbidden_set and (b_pos, -1) not in visited:
                    visited.add((b_pos, -1))
                    queue.append((b_pos, -1))

            # 当前层处理完毕，步数加 1
            steps += 1

        return -1

TC: O(max_bound)
SC: O(max_bound)