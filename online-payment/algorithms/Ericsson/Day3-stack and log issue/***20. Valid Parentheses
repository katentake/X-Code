class Solution:
    def isValid(self, s: str) -> bool:
        stack = []

        for char in str:
            if char == '(':
                stack.append(')')
            elif char == '[':
                stack.append(']')
            elif char == '{':
                stack.append('}')
            elif not stack or stack.pop() != char: #配对之后还有多余的括号
                return False
        
        return not stack #for case like this "(("

#TC: O(N)
