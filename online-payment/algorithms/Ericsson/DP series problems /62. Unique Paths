#二维 DP
class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        # 初始化 m x n 的矩阵，第一行和第一列都为 1
        #m 是rows, n 是cols
        #[1]*n 会生成一个包含n个 1 的列表
        #for _ in range(m):会做m次循环，每次都生成一个[1]*n
        [[1]*n for _ in range(m)]

        #第0行和第0列不需要计算都是1，所以从第1行第1列开始计算
        for i in range(1, m):
            for j in range(1, n):
                dp[i][j] = dp[i-1][j] + dp[i][j-1]
            
        return dp[m-1][n-1]

TC: O(M*N)
SC: O(M*N)

#一维 DP
class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        # 只维护一行的状态
        row = [1] * n
        
        for i in range(1, m):
            for j in range(1, n):
                # row[j] 此时还是上一行的旧值，row[j-1] 是当前行刚更新的左侧值
                row[j] += row[j-1]
                
        return row[-1]

TC: O(M*N)
SC: O(N)
