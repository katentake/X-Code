import heapq

class Solution:
    def findKthLargest(self, nums: List[int], k: int) -> int:
        min_heap = [] # 维护一个大小为 k 的最小堆

        for num in nums:
            if len(min_heap) < k:
                heapq.heappush(min_heap, num)
            else:
                heapq.heappushpop(min_heap, num) #先把 num 放进堆里（此时堆大小变成 k+1）；自动弹出堆中最小的那个元素（此时堆大小恢复回 k）。

        return min_heap[0] ## 堆顶就是

#TC: O(n log k)
#SC: O(k)
