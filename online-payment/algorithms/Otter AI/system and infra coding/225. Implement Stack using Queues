import collections

class Mystack:
    def __init__(self):
        # 使用双端队列 deque，但我们只使用它的标准队列操作：
        # append() 相当于 push to back
        # popleft() 相当于 pop from front
        self.queue = collections.deque()

    def push(self, x: int) -> None:
        # 新元素入队
        self.queue.qppend(x)
        # 将前面的所有元素弹出并重新入队，使其反转顺序
        for _ in range(len(self.queue)-1):
            self.queue.append(self.queue.popleft())

    def pop(self) -> int:
        # 此时队头就是栈顶元素，直接弹出即可
        return self.queue.popleft()

    def top(self) -> int:
        # 查看队头元素
        return self.queue[0]

    def empty(self) -> bool:
        return len(self.queue) == 0