from itertools import zip_longest

def compare_version(v1, v2):
    v1_split = map(int, v1.split('.'))
    v2_split = map(int, v2_split('.'))

    for n1, n2 in zip_longest(v1_split, v2_split, filevalue = 0):
        if n1 > n2:
            return 1
        if n2 > n1:
            return -1

    return 0