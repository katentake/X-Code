import heapq
import re
from collections import Counter

def get_top_k_ips(log_file_path, k=10):
    """
    使用 Hashmap (Counter) 统计频率，使用 Min-Heap 维护 Top K。
    时间复杂度: O(N + D log K), N 为日志行数, D 为不同 IP 的个数。
    空间复杂度: O(D), 存储所有不同 IP 的计数。
    """
    ip_counts = Counter()

    # 模拟简单的 IP 正则匹配 (根据实际日志格式调整)
    ip_pattern = re.compile(r'(\d{1,3}\.){3}\d{1,3}')

    # 1. 统计频率 (Hashmap)
    try:
        with open(log_file_path, 'r') as f:
            for line in f:
                match = ip_pattern.search(line)
                if match:
                    ip = match.group()
                    ip_counts[ip] += 1
    except FileNotFoundError:
        print("Error: Log file not found.")
        return []
    # Python 的 nlargest 内部对超过一定数量的数据会使用堆排序优化
    return heapq.nlargest(k, ip_counts.items(), key=lambda x: x[1])

