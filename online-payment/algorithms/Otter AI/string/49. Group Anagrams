class Solution:
    def groupAnagrams(self, strs: List[List[str]]) -> List[List[str]]:
        res = defaultdict(list) #创建一个默认值为列表的字典

        for s in strs:
            # 将字符串排序并作为 key (必须转回 tuple 或 string，因为 list 不可哈希)
            key = "".join(sorted(s)) #拼接成一个key，例如"aet"
            res[key].append(s) #将原始字符串 s 添加到其对应排序后 key 的列表中，例如：res["aet"] 现在包含了 ["eat", "tea"]
        return list(res.values()) #res.values() 会返回字典中所有的列表； list(...) 将这些结果转换成题目要求的格式并返回

TC: O(N.KlogK)
SC: O(N.K)
