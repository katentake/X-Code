class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        slow = 0 #慢指针，指向当前已确认的不重复元素的最后一个位置
        
        # fast 是快指针，用来扫描整个数组
        for fast in range(len(nums)):
            if nums[slow] != nums[fast]: # 当快指针发现了一个和慢指针位置不同的新元素
                slow += 1
                nums[slow] = nums[fast] # 把新元素复制到慢指针的下一个位置
        
        return slow + 1            # 长度等于最大索引值 + 1