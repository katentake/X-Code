class Solution:
    def reverseWords(self, s: str) -> str:
        s = s.split() #先将string拆分成List["word1", "word2", "word3", ...]

        left, right = 0, len(s)-1 #双指针

        while left < right:
            s[left], s[right] = s[right], s[left] #前后对调
            left += 1
            right -= 1
        return "".join(s) #重新合成一个新的string

TC：O(N)
SC: O(N)