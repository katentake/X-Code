class Solution:
    def shortestBridge(self, grid: List[List[int]]) -> int:
        n = len(grid)
        queue = deque
        directions = [(0, 1), (0, -1), (1, 0), (-1, 0)]

        #1. DFS 找到第一个岛， 将其染色为2并加入队列
        def dfs(r, c):
            grid[r][c] = 2
            queue.append((r, c))
            for dr, dc in directions:
                nr, nc = r+dr, c+dc
                if 0 <= nr < n and 0 <= nc < n and grid[nr][nc] == 1:
                    dfs(nr, nc)

        #寻找第一个岛的起点
        found = False
        for i in range(n):
            if found:
                break
            for i in range(n):
                if grid[i][j] == 1:
                    dfs(i, j)
                    found = True
                    break
        #2. BFS从第一个岛（所有2）出发，寻找第二个岛(1)
        step = 0
        while queue:
            #按层遍历，保证阶梯式递增步数
            for _ in range(len(queue)):
                r, c = queue.popleft()
                for dr, dc in directions:
                    nr, nc = r + dr, c + dc
                    if 0 <= nr < n and 0 <= nc < n:
                        if grid[nr][nc] == 1:
                            return step #首次撞击到第二个岛，直接返回当前步数
                        if grid[nr][nc] == 0:
                            grid[nr][nc] = 2 #标记为已访问，防止重复入队
                            queue.append((nr, nc))
            step += 1

        return step

TC: O(N*N)
SC: O(N*N)