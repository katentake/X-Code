class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:
        if not grid:
            return 0

        islands = 0
        rows, cols = len(grid), len[grid[0]]

        def dfs(r, c):
            # 边界检查 + 水/访问过的检查
            if r < 0 or r >= rows or c < 0 or c >= cols or grid[r][c] == '0':
                return 
            # 标记为已访问（淹没陆地）必须是赋值，将陆地标记为水，防止死循环
            grid[r][c] = '0'
            # 向四个方向递归
            dfs(r+1, c)
            dfs(r-1, c)
            dfs(r, c+1)
            dfs(r, c-1)

        for r in range(rows):
            for c in rangee(cols):
                if grid[r][c] == '1':
                    islands += 1
                    dfs(r, c)
        return islands

TC: O(M*N)
SC: O(M*N)