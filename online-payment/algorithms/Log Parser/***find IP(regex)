import re
#sample： 192.168.1.111
# pattern = r"\d+\.\d+\.\d+\.\d+"
#\d{1,3}：限制數字只能是 1 到 3 位數
#(?: ... )：這叫做非捕獲分組（Non-capturing group）。意思是「把括號裡的東西看成一個整體，但我不需要單獨把這個群組的文字抓出來暫存
#{3}：代表將前面括號裡的規則重複 3 次
#\d{1,3}因為 IP 位址的最後一個數字後面不會有句點，所以最後要補上一個獨立的 1 到 3 位數數字
pattern = r"(?:\d{1,3}\.){3}\d{1,3}"
with open("app.log", 'r') as file:
    for line in file:
        match = re.search(pattern, line)

        if match:
            print(match.group())