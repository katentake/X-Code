1.Method: DP

class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        # curr_sum 维护当前子数组的和，max_sum 记录全局最大和
        curr_sum = max_sum = nums[0]

        for x in nums[1:]:
            # 核心状态转移：如果当前和变成负数，不如从 x 重新开始
            curr_sum = max(x, curr_sum + x)
            max_sum = max(max_sum, curr_sum)

        return max_sum

TC: O(N)
SC: O(1)


2.Method: Divide and Conquer

class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        def findBestSubarray(l, r):
            if l > r:
                return float('-inf)
            if l == r:
                return nums[l]

            mid = (l + r) // 2

            # 1. 跨越中间的情况：从 mid 向左扫描找到最大和
            left_sum = 0
            curr = 0
            for i in range(mid-1, l-1, -1):
                curr += nums[i]
                left_sum = max(left_sum, curr)

            # 从 mid 向右扫描找到最大和
            right_sum = 0
            curr = 0
            for i in range(mid+1, r+1):
                curr += nums[i]
                right_sum = max(right_sum, curr)

            # 跨越中点的最大和是：左边最大 + 中点值 + 右边最大
            cross_sum = left_sum + nums[mid] + right_sum
            return max(cross_sum, findBestSubarray(l, mid-1), findBestSubarray(mid+1, r))

        return findBestSubarray(0, len(nums)-1)

TC: O(n log n)
SC: O(log n)
