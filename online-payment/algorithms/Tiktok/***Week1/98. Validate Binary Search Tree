#Method: Inorder Traversal

class Solution:
    def __init__(self):
        self.prev = -float('inf') # 记录前一个节点的值

    def isValidBST(self, root: Optional[TreeNode]) -> bool:
        if not root:
            return True 
        
        # 1. 先访问左子树
        if not self.isValidBST(root.left):
            return False
        
        # 2. 访问当前节点：必须严格大于前一个节点
        if root.val <= self.prev:
            return False
        self.prev = root.val # 更新 prev 为当前值

        # 3. 再访问右子树
        return self.isValidBST(root.right)

TC: O(n)
SC: O(n)
