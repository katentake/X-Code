class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        count = 0
        curr_sum = 0
        hashmap = {0:1}

        for num in nums:
            curr_sum += num #计算当前的前缀和
            if curr_sum - k in hashmap: #如果结果在hashmap中，说明找到了符合的子数组
                count += hashmap[curr_sum - k]
            # 将当前前缀和存入hashmap
            # 看看这个前缀和之前出现了几次。如果出现了 N 次，现在就变成 N + 1 次；如果以前没出现过，现在就是 0 + 1 = 1次
            hashmap[curr_sum] = hashmap.get(curr_sum, 0) + 1

        return count

TC: O(n)
SC: O(n)