class Solution:
    def orangesRotting(self, grid: List[List[int]]) -> int:
        rows, cols = len(grid), len(grid[0])
        queue = deque()
        fresh_oranges = 0
        # 1. 预处理：统计新鲜橘子数量，并将所有腐烂橘子入队
        for r in range(rows):
            for c in range(cols):
                if grid[r][c] == 2:
                    queue.append((r, c))
                elif grid[r][c] == 1:
                    fresh_oranges += 1

        # 如果本来就没有新鲜橘子，直接返回 0
        if fresh_oranges == 0:
            return 0
        # 上下左右四个方向
        mintues = 0
        directions = [(0, 1), (0, -1), (1, 0), (-1, 0)]
        # 2. 开始多源 BFS 扩散
        while queue and fresh_oranges > 0:
            mintues += 1
            # 必须用当前层的长度控制，保证“同时扩散”
            for _ in range(len(queue)):
                r, c = queue.popleft()
                for dr, dc in directions:
                    nr, nc = r+dr, c+dc
                    # 如果索引合法且遇到了新鲜橘子
                    if 0 <= nr < rows and 0 <= nc < cols and grid[nr][nc] == 1:
                        grid[nr][nc] = 2 # 变腐烂
                        fresh_oranges -= 1 # 新鲜橘子减少
                        queue.append((nr, nc)) # 加入下一轮扩散队伍                    

        # 3. 如果最后还有新鲜橘子没被感染，说明不可能全部腐烂，返回 -1
        return minutes if fresh_oranges == 0 else -1

TC: O(m*n)
SC: O(m*n)