class Solution:
    def topKFrequent(self, nums: list[int], k: int) -> list[int]:
        count = Counter(nums)
        min_heap = []

        for num, freq in count.items():
            if len(min_heap) < k:
                heapq.heappush(min_heap, (freq, num))
            else:
                heapq.heappushpop(min_heap, (freq, num))

        res = []
        for item in min_heap:
            res.append(item[1])
        return res

TC: O(n log k)
SC: O(n+k)