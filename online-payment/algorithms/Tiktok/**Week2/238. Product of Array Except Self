Method: 双数组法
class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        L = [1]*len(nums)
        for i in range(1, len(nums)):
            L[i] = L[i-1]*nums[i-1]

        R = [1]*len(nums)
        for i in range(len(nums)-2, -1, -1):
            R[i] = R[i+1]*nums[i+1]

        res = [1]*len(nums)
        for i in range(len(nums)):
            res[i] = L[i] * R[i]

        return res

TC: O(n)
SC: O(n)