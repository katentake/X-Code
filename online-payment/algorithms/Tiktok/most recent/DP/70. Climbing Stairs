#Method: dp 动态规划+空间优化（滚动变量）

class Solution:
    def climbstairs(self, n: int) -> int:
        if n < 2:
            return n 

        a, b = 1, 2 #a 代表到达第一阶有1种方法； b 代表到达第2阶有2种方法 
        for _ in range(3, n+1):
            #新的 a 顶替成了旧的 b（即上一步的结果）
            #新的 b 变成了 a + b（即前两步方法数之和，也就是当前台阶的答案）
            a, b = b, a+b 
        return b 

TC: O(n)
SC: O(1)