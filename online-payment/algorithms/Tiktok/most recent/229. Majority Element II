class Solution:
    def majorityElement(self, nums: List[int]) -> List[int]:
        #edge case 
        if not nums:
            return []
        # 1. 统计每个数字出现的频次
        count = Counter(nums)
        res = []
        target = len(nums) // 3

        # 2. 挑选出超过 n/3 次的数字
        for num, freq in count.items():
            if freq > target:
                res.append(num)

        return res

TC: O(N)
SC: O(N)