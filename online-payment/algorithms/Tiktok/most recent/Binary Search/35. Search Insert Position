#Method: Binary Search

class Solution:
    def searchInsert(self, nums: List[int], target: int) -> int:
        left, right = 0, len(nums)

        while left < right:
            mid = (left + right) // 2
            if nums[mid] < target:
                left = mid +1  # mid 及左边都比 target 小，直接跳到 mid + 1
            else:
                right = mid  # target <= nums[mid]，因为是右开区间，右边界缩到 mid

        return left 


TC: O(log n)
SC: O(1)