class Solution:
    def lowestCommonAncestor(self, root: 'TreeNode', p: 'TreeNode', q: 'TreeNode') -> 'TreeNode':
        if not root: #Edge case
            return None

        if root == p or root == q:
            return root

        #recursion left tree and right tree
        left = self.lowestCommonAncestor(root.left, p, q)
        right = self.lowestCommonAncestor(root.right, p, q)
        #如果左右子树都有节点，说明p,q 分居两侧，当前节点即为LCA
        if left and right:
            return root
        #如果只有一边找到了，说明LCA在那一侧，或者p,q在一侧，位置为上下
        if left:
            return left
        if right:
            return right
        