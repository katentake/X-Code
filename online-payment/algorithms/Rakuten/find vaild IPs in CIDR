def is_ip_in_network(ip_str, network_cidr):
    try:
        ip = ipaddress.ip_address(ip_str)
        network = ipaddress.ip_network(network_cidr)
        # 直接使用 in 关键字判断，支持不同版本的兼容检查
        return ip in network
    except ValueError:
        return False

# test fuction:
print(is_ip_in_network("192.168.1.50", "192.168.1.0/24"))
