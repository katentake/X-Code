#Method 1: slice
class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:
        nums[:] = [x for x in nums if x != val] # 过滤掉 val，并原地覆盖原数组
        return len(nums)


#Method 2:two pointer --slow and fast
class Solution:
    def removeElement(self, nums: List[int], val: int) -> int
    slow = 0 # slow 指针表示下一个非 val 元素存放的位置

    for fast in range(len(nums)):
        if nums[fast] != val: # 如果当前元素不是要删除的 val
            nums[slow] = nums[fast] # 将快指针指向的值赋给慢指针所在位置
            slow += 1 # 慢指针向前移动一步

    return slow # 遍历结束后，slow 的数值正好就是新数组的长度


#Method 3: 对撞指针法 (Two Pointers - Optimization)
class Solution:
    def removeElement(self, nums: List[int], val: int) -> int:
        left, right = 0, len(nums)

        while left < right:
            if nums[left] == val:
                nums[left] = nums[right-1] # 发现要删除的元素，直接把最后一个元素挪过来覆盖它
                right -= 1 # 数组总长度减 1，但 left 不动（因为挪过来的新元素也可能等于 val）
            else:
                left += 1
        return left