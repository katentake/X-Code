class Solution:
    def simplelifypath:(self, path: str) -> str:
        stack = []
        list_path = path.split('/) #将字符串用/分开， 例如 "/home//foo/" -> ["", "home", "", "foo", ""]

        for i in list_path:
            if i == "" or i == ".": # 情况 1 & 3：如果是空字符（//）或者是 '.'，跳过
                continue
            elif i == "..": # 情况 2：如果是 '..'，尝试回退一级（弹出栈顶）
                if stack:
                    stack.pop()
            else: # 情况 4：合法的目录名，入栈
                stack.append(i)

        res = "/" + "/".join(stack) # 2. 将栈中的目录用 '/' 重新连接，并在开头加上根目录 '/'

        return res